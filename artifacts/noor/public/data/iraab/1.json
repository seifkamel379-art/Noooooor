{"1":[{"w":"بِسْمِ","m":"In (the) name","r":"bis'mi"},{"w":"ٱللَّهِ","m":"(of) Allah","r":"l-lahi"},{"w":"ٱلرَّحْمَـٰنِ","m":"the Most Gracious","r":"l-raḥmāni"},{"w":"ٱلرَّحِيمِ","m":"the Most Merciful","r":"l-raḥīmi"}],"2":[{"w":"ٱلْحَمْدُ","m":"All praises and thanks","r":"al-ḥamdu"},{"w":"لِلَّهِ","m":"(be) to Allah","r":"lillahi"},{"w":"رَبِّ","m":"the Lord","r":"rabbi"},{"w":"ٱلْعَـٰلَمِينَ","m":"of the universe","r":"l-ʿālamīna"}],"3":[{"w":"ٱلرَّحْمَـٰنِ","m":"The Most Gracious","r":"al-raḥmāni"},{"w":"ٱلرَّحِيمِ","m":"the Most Merciful","r":"l-raḥīmi"}],"4":[{"w":"مَـٰلِكِ","m":"(The) Master","r":"māliki"},{"w":"يَوْمِ","m":"(of the) Day","r":"yawmi"},{"w":"ٱلدِّينِ","m":"(of the) Judgment","r":"l-dīni"}],"5":[{"w":"إِيَّاكَ","m":"You Alone","r":"iyyāka"},{"w":"نَعْبُدُ","m":"we worship","r":"naʿbudu"},{"w":"وَإِيَّاكَ","m":"and You Alone","r":"wa-iyyāka"},{"w":"نَسْتَعِينُ","m":"we ask for help","r":"nastaʿīnu"}],"6":[{"w":"ٱهْدِنَا","m":"Guide us","r":"ih'dinā"},{"w":"ٱلصِّرَٰطَ","m":"(to) the path","r":"l-ṣirāṭa"},{"w":"ٱلْمُسْتَقِيمَ","m":"the straight","r":"l-mus'taqīma"}],"7":[{"w":"صِرَٰطَ","m":"(The) path","r":"ṣirāṭa"},{"w":"ٱلَّذِينَ","m":"(of) those","r":"alladhīna"},{"w":"أَنْعَمْتَ","m":"You have bestowed (Your) Favors","r":"anʿamta"},{"w":"عَلَيْهِمْ","m":"on them","r":"ʿalayhim"},{"w":"غَيْرِ","m":"not (of)","r":"ghayri"},{"w":"ٱلْمَغْضُوبِ","m":"those who earned (Your) wrath","r":"l-maghḍūbi"},{"w":"عَلَيْهِمْ","m":"on themselves","r":"ʿalayhim"},{"w":"وَلَا","m":"and not","r":"walā"},{"w":"ٱلضَّآلِّينَ","m":"(of) those who go astray","r":"l-ḍālīna"}]}