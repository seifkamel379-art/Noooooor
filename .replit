modules = ["nodejs-20", "web", "bash", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/noor/start-dev.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[agent]
stack = "FULLSTACK_JS"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "noooooor-app.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "noooooor-app"
VITE_FIREBASE_STORAGE_BUCKET = "noooooor-app.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "230599694330"
VITE_FIREBASE_APP_ID = "1:230599694330:web:8780636368d1469591f643"
VITE_FIREBASE_MEASUREMENT_ID = "G-P96TYMPZQF"
VITE_FIREBASE_API_KEY = "AIzaSyDOVE54x_j5fldKYwTRAG9QzdRok_pD074"

[nix]
channel = "stable-25_05"
packages = ["freetype", "gumbo", "harfbuzz", "jbig2dec", "killall", "libjpeg_turbo", "mupdf", "openjpeg", "swig", "xcbuild", "zip", "zulu17"]

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80
