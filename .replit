modules = ["nodejs-20", "web", "java-graalvm22.3"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "noooooor-app.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "noooooor-app"
VITE_FIREBASE_STORAGE_BUCKET = "noooooor-app.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "230599694330"
VITE_FIREBASE_APP_ID = "1:230599694330:web:8780636368d1469591f643"
VITE_FIREBASE_MEASUREMENT_ID = "G-P96TYMPZQF"
VITE_FIREBASE_API_KEY = "AIzaSyDOVE54x_j5fldKYwTRAG9QzdRok_pD074"

[nix]
channel = "stable-25_05"
packages = ["zulu17", "zip"]

[[ports]]
localPort = 19382
externalPort = 80
