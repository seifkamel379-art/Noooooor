{
  "version": 2,
  "buildCommand": "cd /vercel/path0 && pnpm exec vite build --config vite.config.ts",
  "outputDirectory": "dist/public",
  "installCommand": "cd /vercel/path0 && pnpm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
